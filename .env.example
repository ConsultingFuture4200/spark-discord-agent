# ---------------------------------------------------------------------------
# Discord Agent — environment configuration
# Copy to .env and fill in. .env is gitignored; never commit real secrets.
# Values are validated at startup by packages/shared loadConfig().
# ---------------------------------------------------------------------------

# --- Discord ---------------------------------------------------------------
# Bot token from the Discord Developer Portal (Bot -> Reset Token).
DISCORD_TOKEN=
# Application (client) ID — used to register slash commands.
DISCORD_APP_ID=
# The single private guild (server) this agent operates in.
DISCORD_GUILD_ID=
# Comma-separated voice channel IDs that are armed for auto-record.
# Empty = no channels auto-record until armed via slash command.
DISCORD_AUTORECORD_CHANNEL_IDS=
# Optional: comma-separated role/user IDs that trigger auto-join when they
# join an armed channel. Empty = trigger on any non-bot human (>=1 present).
DISCORD_TRIGGER_ROLE_IDS=
DISCORD_TRIGGER_USER_IDS=

# --- Local inference (Ollama, OpenAI-compatible endpoint on the Spark) ------
# Spark reachable over Tailscale (MagicDNS name or 100.x.y.z). The bot may run
# on the Spark or on any tailnet host that can reach these endpoints.
OLLAMA_BASE_URL=http://spark:11434/v1
# Small, fast model for interactive text (DMs / channel replies).
OLLAMA_INTERACTIVE_MODEL=qwen2.5:7b
# Large model for post-call batch summarization.
OLLAMA_BATCH_MODEL=qwen2.5:32b
# Optional API key if the endpoint is protected (Ollama ignores it by default).
OLLAMA_API_KEY=

# --- Transcription (faster-whisper) ----------------------------------------
# Whisper model size/name loaded by the processing service.
WHISPER_MODEL=large-v3
# Compute type for CTranslate2 (e.g. float16, int8_float16, int8).
WHISPER_COMPUTE_TYPE=float16
# OpenAI-compatible faster-whisper HTTP service (POST {base}/audio/transcriptions).
# Read directly by packages/processing.
# Spark reachable over Tailscale (MagicDNS name or 100.x.y.z).
WHISPER_BASE_URL=http://spark:8000/v1
# Optional language hint (ISO-639-1). Empty = auto-detect.
WHISPER_LANGUAGE=
# Optional bearer token if the STT endpoint is protected.
WHISPER_API_KEY=

# --- Processing service ----------------------------------------------------
# How often the batch watcher polls the storage dir for ready-to-process calls.
PROCESSING_POLL_INTERVAL_MS=5000
# A call left transcribing/summarizing longer than this (ms) is treated as a
# crashed run and re-enqueued. Must exceed worst-case processing time. 15 min.
PROCESSING_STALE_LEASE_MS=900000

# --- Email (provider-agnostic IMAP read + SMTP send) -----------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_TLS=true

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true
# From address the agent sends as.
AGENT_EMAIL_FROM=
# Recipient for post-call summary emails (FR-19). Optional; defaults to
# AGENT_EMAIL_FROM (the agent's own inbox) when email is configured.
SUMMARY_EMAIL_TO=

# --- Storage & retention ---------------------------------------------------
# Base directory for per-call data (audio tracks, manifest, transcript, summary).
STORAGE_DIR=./data/calls
# Days to retain raw audio before auto-purge. Transcripts/summaries kept indefinitely.
AUDIO_RETENTION_DAYS=7

# --- Runtime ---------------------------------------------------------------
LOG_LEVEL=info
